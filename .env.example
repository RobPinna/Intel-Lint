# LLM-first defaults (recommended for normal usage)
ENGINE=ollama
OLLAMA_URL=http://localhost:11434
MODEL=FenkoHQ/Foundation-Sec-8B

# Backward-compatible aliases used by current code paths
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=FenkoHQ/Foundation-Sec-8B

# Optional runtime tuning
